# Database (Railway provides this automatically when you add a PostgreSQL plugin)
DATABASE_URL="postgresql://soc_admin:soc_password_2024@localhost:5433/soc_training?schema=public"

# JWT (CHANGE THESE IN PRODUCTION)
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Server (Railway sets PORT automatically)
SERVER_PORT=3001
NODE_ENV=development

# Client
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000
