# Database (Railway provides this automatically when you add a PostgreSQL plugin)
DATABASE_URL="postgresql://soc_admin:soc_password_2024@localhost:5433/soc_training?schema=public"

# JWT (CHANGE THESE IN PRODUCTION)
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="4h"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Server (Railway sets PORT automatically)
SERVER_PORT=3001
NODE_ENV=development

# Client
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# AI Features (optional — leave empty to disable AI scoring, assistant, and scenario generation)
ANTHROPIC_API_KEY=
AI_DAILY_LIMIT=30

# Security
ALLOW_DEMO_CREDENTIALS=true          # Set to 'true' to allow demo logins (default: blocked in production)
SOCKET_MAX_CONNECTIONS=500            # Max total WebSocket connections server-wide
AI_DAILY_ORG_LIMIT=500               # Organization-wide daily AI message cap (0 = unlimited)
AI_MAX_CONCURRENT=5                   # Max concurrent AI API calls
